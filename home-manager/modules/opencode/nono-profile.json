{
  "meta": {
    "name": "opencode",
    "version": "1.0.0"
  },
  "extends": "my-default",
  "filesystem": {
    "read": [
      "$HOME/.claude"
    ],
    "allow": [
      "$HOME/.config/opencode",
      "$HOME/.local/share/opencode",
      "$HOME/.cache/opencode",
      "$HOME/.local/state/opencode",

      "$HOME/.config/fish",
      "$HOME/.local/share/fish",

      "/tmp"
    ],
    "read_file": [
    ],
    "write_file": []
  },
  "network": {
    "block": false
  },
  "workdir": {
    "access": "readwrite"
  }
}
